# ─────────────────────────────────────────────────────────────────────────────
# Firebase Configuration — SriKrishna Textile Shop
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO GET THESE VALUES:
# 1. Go to https://console.firebase.google.com/
# 2. Create / open your project
# 3. Click ⚙️ Project Settings → Your Apps → Add Web App
# 4. Copy the firebaseConfig object values into the variables below
#
# ENABLE PROVIDERS:
# Authentication → Sign-in method → Enable Google ✅
# Authentication → Sign-in method → Enable Facebook ✅
#   (For Facebook: paste your Facebook App ID + Secret from developers.facebook.com)
#
# AUTHORISED DOMAIN:
# Authentication → Settings → Authorised Domains → Add → localhost
# (Add your production domain when deploying)
# ─────────────────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
